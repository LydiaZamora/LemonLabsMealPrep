@model Ingredient
@{
    ViewData["Title"] = "Ingredient Details";
}

<h1>@Model.Name</h1>
<dl class="row">
    <dt class="col-sm-2">Organic</dt>
    <dd class="col-sm-10">@(Model.IsOrganic ? "Yes" : "No")</dd>
    <dt class="col-sm-2">Seasonal Availability</dt>
    <dd class="col-sm-10">@Model.SeasonalAvailability</dd>
    <dt class="col-sm-2">Farm</dt>
    <dd class="col-sm-10">@Model.Farm?.Name</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> |
<a asp-action="Index">Back to List</a>
