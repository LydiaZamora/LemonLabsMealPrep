@model Booking
@{
    ViewData["Title"] = "Booking Details";
}

<h1>Booking Details</h1>
<dl class="row">
    <dt class="col-sm-2">User</dt>
    <dd class="col-sm-10">@Model.UserProfile?.Name</dd>
    <dt class="col-sm-2">Chef</dt>
    <dd class="col-sm-10">@Model.Chef?.Name</dd>
    <dt class="col-sm-2">Requested Date</dt>
    <dd class="col-sm-10">@Model.RequestedDate.ToShortDateString()</dd>
    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@Model.Status</dd>
    <dt class="col-sm-2">Notes</dt>
    <dd class="col-sm-10">@Model.Notes</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> |
<a asp-action="Index">Back to List</a>
