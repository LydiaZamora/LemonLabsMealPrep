@model Booking
@{
    ViewData["Title"] = "Edit Booking";
}

<h1>Edit Booking</h1>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group mb-3">
        <label asp-for="UserProfileId" class="control-label">User</label>
        <select asp-for="UserProfileId" class="form-control" asp-items="ViewBag.UserProfileId"></select>
    </div>
    <div class="form-group mb-3">
        <label asp-for="ChefId" class="control-label">Chef</label>
        <select asp-for="ChefId" class="form-control" asp-items="ViewBag.ChefId"></select>
    </div>
    <div class="form-group mb-3">
        <label asp-for="RequestedDate" class="control-label"></label>
        <input asp-for="RequestedDate" class="form-control" />
        <span asp-validation-for="RequestedDate" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label asp-for="Status" class="control-label"></label>
        <select asp-for="Status" class="form-control" asp-items="Html.GetEnumSelectList<BookingStatus>()"></select>
    </div>
    <div class="form-group mb-3">
        <label asp-for="Notes" class="control-label"></label>
        <textarea asp-for="Notes" class="form-control"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
